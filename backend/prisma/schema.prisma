generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Cliente {
  id                   String               @id @default(uuid())
  codigoCliente        String?              @unique
  nombre               String
  alias                String?
  rif                  String               @unique
  direccion            String?
  telefono             String?
  email                String?
  creadoEn             DateTime             @default(now())
  ventas               Venta[]
  cotizaciones         Cotizacion[]
  movimientosContables MovimientoContable[]
  cuentasStarlink      CuentaStarlink[]
  antenasStarlink      AntenaStarlink[]
  pagosStarlink        PagoStarlink[]
}

model Venta {
  id        String   @id @default(uuid())
  clienteId String
  cliente   Cliente  @relation(fields: [clienteId], references: [id])
  linea     String
  base      Float
  iva       Float
  total     Float
  estado    String   @default("Por cobrar")
  fecha     DateTime @default(now())
}

enum DocumentoTipo {
  PROPUESTA
  PRESUPUESTO
}

model Cotizacion {
  id                       String        @id @default(uuid())
  numero                   String        @unique
  tipoDocumento            DocumentoTipo @default(PROPUESTA)
  clienteId                String
  cliente                  Cliente       @relation(fields: [clienteId], references: [id])
  fecha                    DateTime      @default(now())
  vigencia                 String
  condiciones              String
  subtotal                 Float
  iva                      Float
  total                    Float
  items                    Json
  titulo                   String?
  contenidoPropuesta       String?
  datosPdf                 Json?
  clienteCodigoSnapshot    String?
  clienteNombreSnapshot    String?
  clienteRifSnapshot       String?
  clienteDireccionSnapshot String?
  clienteTelefonoSnapshot  String?
  clienteEmailSnapshot     String?
  estado                   String        @default("BORRADOR")
  deletedAt                DateTime?
  asociaciones             CotizacionAsociacion[]
}

model CotizacionAsociacion {
  id           String     @id @default(uuid())
  cotizacionId String
  cotizacion   Cotizacion @relation(fields: [cotizacionId], references: [id], onDelete: Cascade)
  tipo         String
  productoId   String?
  producto     Producto?  @relation(fields: [productoId], references: [id], onDelete: SetNull)
  servicioId   String?
  servicio     Servicio?  @relation(fields: [servicioId], references: [id], onDelete: SetNull)
  cantidad     Float      @default(1)
  precioUsd    Float?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([cotizacionId])
  @@index([productoId])
  @@index([servicioId])
}

model PlantillaDocumento {
  id                 String   @id @default(uuid())
  nombre             String
  tipoDocumento      String   @default("AMBOS")
  descripcion        String?
  titulo             String?
  contenidoPropuesta String?
  condiciones        String?
  datosPdf           Json?
  activo             Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  deletedAt          DateTime?

  @@index([tipoDocumento, activo])
}

model Tasa {
  id       String   @id @default(uuid())
  bcv      Float
  paralelo Float
  fecha    DateTime @default(now())
}

enum MovimientoTipo {
  INGRESO
  EGRESO
  CUENTA_POR_COBRAR
  CUENTA_POR_PAGAR
}

enum MovimientoEstado {
  PENDIENTE
  PAGADO
  VENCIDO
  ANULADO
}

model MovimientoContable {
  id                String           @id @default(uuid())
  tipo              MovimientoTipo
  categoria         String?
  concepto          String
  descripcion       String?
  montoUsd          Float
  tasaBcv           Float?
  montoBs           Float?
  tasaFuente        String?
  tasaFecha         DateTime?
  tasaEditadaManual Boolean          @default(false)
  fechaMovimiento   DateTime
  fechaVencimiento  DateTime?
  estado            MovimientoEstado @default(PENDIENTE)
  metodoPago        String?
  clienteId         String?
  cliente           Cliente?         @relation(fields: [clienteId], references: [id])
  proveedorId       String?
  productoId        String?
  producto          Producto?        @relation(fields: [productoId], references: [id])
  servicioId        String?
  servicio          Servicio?        @relation(fields: [servicioId], references: [id])
  tipoProductoId    String?
  tipoProducto      TipoProducto?    @relation(fields: [tipoProductoId], references: [id])
  tipoServicioId    String?
  tipoServicio      TipoServicio?    @relation(fields: [tipoServicioId], references: [id])
  referencia        String?
  movimientoRelacionadoId String?
  movimientoRelacionado   MovimientoContable?  @relation("MovimientoRelacionado", fields: [movimientoRelacionadoId], references: [id], onDelete: SetNull)
  movimientosRelacionados MovimientoContable[] @relation("MovimientoRelacionado")
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([movimientoRelacionadoId])
}

model Usuario {
  id           String     @id @default(uuid())
  nombre       String
  email        String     @unique
  passwordHash String
  rol          String     @default("USUARIO")
  activo       Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  auditLogs    AuditLog[]
}

model AuditLog {
  id          String   @id @default(uuid())
  usuarioId   String?
  usuario     Usuario? @relation(fields: [usuarioId], references: [id])
  accion      String
  entidad     String
  entidadId   String?
  descripcion String
  metadata    Json?
  ip          String?
  userAgent   String?
  createdAt   DateTime @default(now())
}

model ConfiguracionSistema {
  clave     String   @id
  valor     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TipoServicio {
  id                   String               @id @default(uuid())
  nombre               String               @unique
  descripcion          String?
  activo               Boolean              @default(true)
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  servicios            Servicio[]
  movimientosContables MovimientoContable[]
}

model Servicio {
  id                   String               @id @default(uuid())
  codigoServicio       String?              @unique
  nombre               String
  descripcion          String?
  tipoServicioId       String?
  tipoServicio         TipoServicio?        @relation(fields: [tipoServicioId], references: [id])
  precioUsd            Float                @default(0)
  activo               Boolean              @default(true)
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  movimientosContables MovimientoContable[]
  cotizacionAsociaciones CotizacionAsociacion[]
}

model TipoProducto {
  id                   String               @id @default(uuid())
  nombre               String               @unique
  descripcion          String?
  activo               Boolean              @default(true)
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  productos            Producto[]
  movimientosContables MovimientoContable[]
}

model Producto {
  id                   String               @id @default(uuid())
  codigoProducto       String?              @unique
  nombre               String
  descripcion          String?
  tipoProductoId       String?
  tipoProducto         TipoProducto?        @relation(fields: [tipoProductoId], references: [id])
  precioUsd            Float                @default(0)
  stock                Int?
  activo               Boolean              @default(true)
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  movimientosContables MovimientoContable[]
  cotizacionAsociaciones CotizacionAsociacion[]
}

model Proveedor {
  id              String   @id @default(uuid())
  codigoProveedor String?  @unique
  nombre          String
  rif             String?  @unique
  direccion       String?
  telefono        String?
  email           String?
  tipoEmpresa     String?
  activo          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model CuentaStarlink {
  id             String            @id @default(uuid())
  clienteId      String
  cliente        Cliente           @relation(fields: [clienteId], references: [id])
  nombreCuenta   String
  correoCuenta   String?
  referencia     String?
  tipoServicio   String            @default("SERVICIO_COMPLETO")
  montoMensualUsd Float?
  fechaCorte     DateTime?
  estado         String            @default("ACTIVA")
  observaciones  String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  antenas        AntenaStarlink[]
  pagos          PagoStarlink[]
}

model AntenaStarlink {
  id               String          @id @default(uuid())
  clienteId        String
  cliente          Cliente         @relation(fields: [clienteId], references: [id])
  cuentaStarlinkId String?
  cuentaStarlink   CuentaStarlink? @relation(fields: [cuentaStarlinkId], references: [id])
  numeroKit        String?         @unique
  numeroSerie      String?
  nombreAntena     String
  ubicacion        String?
  fechaRegistro    DateTime        @default(now())
  fechaCorte       DateTime?
  tipoServicio     String          @default("SERVICIO_COMPLETO")
  estado           String          @default("ACTIVA")
  observaciones    String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

model PagoStarlink {
  id                  String          @id @default(uuid())
  cuentaStarlinkId    String
  cuentaStarlink      CuentaStarlink  @relation(fields: [cuentaStarlinkId], references: [id])
  clienteId           String
  cliente             Cliente         @relation(fields: [clienteId], references: [id])
  periodo             String
  montoUsd            Float
  tasaBcv             Float?
  montoBs             Float?
  fechaPago           DateTime?
  fechaCorte          DateTime
  estado              String          @default("PENDIENTE")
  referencia          String?
  movimientoContableId String?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
}

model Empleado {
  id              String   @id @default(uuid())
  codigoEmpleado  String?  @unique
  nombre          String
  apellido        String?
  cedula          String?  @unique
  cargo           String?
  telefono        String?
  email           String?
  fechaIngreso    DateTime?
  salarioBaseUsd  Float?
  activo          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  nominas         Nomina[]
}

model Nomina {
  id                  String   @id @default(uuid())
  empleadoId          String
  empleado            Empleado @relation(fields: [empleadoId], references: [id])
  periodo             String
  salarioBaseUsd      Float
  bonosUsd            Float    @default(0)
  deduccionesUsd      Float    @default(0)
  totalUsd            Float
  tasaBcv             Float?
  totalBs             Float?
  fechaPago           DateTime?
  estado              String   @default("PENDIENTE")
  referencia          String?
  movimientoContableId String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}
